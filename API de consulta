API de Consulta de CEP


import requests

print("=== CONSULTA DE CEP ===")

cep = input("Digite o CEP (somente números): ").strip()

if not cep.isdigit() or len(cep) != 8:
    print("CEP inválido! Digite exatamente 8 números.")
else:
    url = f"https://viacep.com.br/ws/{cep}/json/"

    try:
        resposta = requests.get(url)
        dados = resposta.json()

        if "erro" in dados:
            print("CEP não encontrado!")
        else:
            print("\nEndereço encontrado:")
            print("Rua:", dados["logradouro"])
            print("Bairro:", dados["bairro"])
            print("Cidade:", dados["localidade"])
            print("Estado:", dados["uf"])

    except:
        print("Erro ao conectar com a API.")
